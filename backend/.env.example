# ─── App ───────────────────────────────────────────────
APP_NAME="AI Code Review Agent"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars

# ─── Database ──────────────────────────────────────────
DATABASE_URL=sqlite:///./codereviewer.db

# ─── Free LLM: Groq ────────────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096

# ─── Embeddings: Sentence Transformers (100% free local)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Vector DB: ChromaDB (free, local) ─────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=code_reviews

# ─── GitHub OAuth ──────────────────────────────────────
# Create app at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# ─── JWT ───────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# ─── Frontend ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
